rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (request.auth.token.email == 'ridhoradyapratama4@gmail.com' && request.auth.token.email_verified == true); 
    }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Users ---
    function isValidUser(data) {
      return data.role in ['seeker', 'owner', 'admin']
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && (data.keys().hasAll(['role', 'name', 'email']));
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if (isOwner(userId) || isAdmin()) 
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'whatsappNumber', 'cvUrl', 'cvs', 'role', 'isVerified']));
    }

    // --- Jobs ---
    function isValidJob(data) {
      return (data.category is string) && data.category.size() <= 50
        && data.type in ['Part-time', 'Full-time']
        && data.status in ['active', 'closed']
        && data.title is string && data.title.size() <= 100
        && data.outletName is string && data.outletName.size() <= 100
        && data.province is string && data.province.size() <= 100
        && data.city is string && data.city.size() <= 100
        && data.ownerId is string && data.ownerId.size() <= 128
        && (data.keys().hasAll(['ownerId', 'outletName', 'title', 'category', 'province', 'city', 'location', 'type', 'status', 'createdAt']));
    }

    match /jobs/{jobId} {
      allow get: if isValidId(jobId);
      allow list: if (resource.data.status == 'active') || (isSignedIn() && (resource.data.ownerId == request.auth.uid)) || isAdmin(); 
      allow create: if isSignedIn() && isValidJob(incoming()) && isOwner(incoming().ownerId) && incoming().createdAt == request.time;
      allow update: if (isSignedIn() && (isOwner(existing().ownerId) || isAdmin()))
        && (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'location', 'province', 'city', 'salary', 'type', 'status', 'whatsappContact', 'posterUrl']));
      allow delete: if (isSignedIn() && (isOwner(existing().ownerId) || isAdmin()));
    }

    // --- Applications ---
    function isValidApplication(data) {
      return data.status in ['pending', 'seen', 'interview', 'accepted', 'rejected']
        && data.seekerName is string && data.seekerName.size() >= 2
        && data.seekerId is string && data.seekerId.size() <= 128
        && data.ownerId is string && data.ownerId.size() <= 128
        && data.jobId is string && data.jobId.size() <= 128
        && (data.keys().hasAll(['jobId', 'ownerId', 'seekerId', 'seekerName', 'seekerEmail', 'seekerWhatsApp', 'status', 'submittedAt']));
    }

    match /applications/{applicationId} {
      allow get: if isSignedIn() && isValidId(applicationId) && (isOwner(existing().seekerId) || isOwner(existing().ownerId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.seekerId == request.auth.uid || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().seekerId) && isValidApplication(incoming()) && incoming().submittedAt == request.time;
      allow update: if (isSignedIn() && (isOwner(existing().ownerId) || isAdmin()))
        && (incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }

    // --- Category Requests ---
    function isValidRequest(data) {
      return data.status in ['pending', 'approved', 'rejected']
        && data.requestedTitle is string && data.requestedTitle.size() > 0 && data.requestedTitle.size() <= 100
        && (data.keys().hasAll(['ownerId', 'requestedTitle', 'status', 'createdAt']));
    }

    match /categoryRequests/{requestId} {
      allow get: if isSignedIn() && isValidId(requestId) && (isOwner(resource.data.ownerId) || isAdmin());
      allow list: if isSignedIn() && (isOwner(resource.data.ownerId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().ownerId) && isValidRequest(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
