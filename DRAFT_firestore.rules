rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && (request.auth.token.email == 'ridhoradyapratama4@gmail.com' && request.auth.token.email_verified == true); }
    
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Users ---
    function isValidUser(data) {
      return data.role in ['seeker', 'owner']
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.email is string && data.email.size() <= 100
        && (data.keys().hasAll(['role', 'name', 'email']));
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) 
        && isValidUser(incoming())
        && (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'whatsappNumber', 'cvUrl', 'role', 'isVerified']));
    }

    // --- Jobs ---
    function isValidJob(data) {
      return data.category in ['Barista', 'Kitchen', 'Waiters', 'Cashier', 'Cleaning Service']
        && data.type in ['Part-time', 'Full-time']
        && data.status in ['active', 'closed']
        && data.title is string && data.title.size() <= 100
        && data.outletName is string && data.outletName.size() <= 100
        && data.location is string && data.location.size() <= 200
        && data.createdAt == request.time
        && (data.keys().hasAll(['ownerId', 'outletName', 'title', 'category', 'location', 'type', 'status', 'createdAt']));
    }

    match /jobs/{jobId} {
      allow read: if true; // Public listings
      allow create: if isSignedIn() && isValidJob(incoming()) && isOwner(incoming().ownerId);
      allow update: if (isSignedIn() && isOwner(existing().ownerId) || isAdmin())
        && isValidJob(incoming())
        && (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'location', 'salary', 'type', 'status', 'whatsappContact']));
      allow delete: if (isSignedIn() && isOwner(existing().ownerId) || isAdmin());
    }

    // --- Applications ---
    function isValidApplication(data) {
      return data.status in ['pending', 'reviewed', 'contacted', 'rejected']
        && data.seekerName is string && data.seekerName.size() >= 2
        && data.submittedAt == request.time
        && (data.keys().hasAll(['jobId', 'seekerId', 'seekerName', 'seekerWhatsApp', 'status', 'submittedAt']));
    }

    match /applications/{applicationId} {
      allow get: if isSignedIn() && (isOwner(existing().seekerId) || isOwner(get(/databases/$(database)/documents/jobs/$(existing().jobId)).data.ownerId) || isAdmin());
      allow list: if isSignedIn() && (resource.data.seekerId == request.auth.uid || get(/databases/$(database)/documents/jobs/$(resource.data.jobId)).data.ownerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().seekerId) && isValidApplication(incoming());
      allow update: if (isSignedIn() && (isOwner(existing().seekerId) || isOwner(get(/databases/$(database)/documents/jobs/$(existing().jobId)).data.ownerId) || isAdmin()))
        && isValidApplication(incoming())
        && (incoming().diff(existing()).affectedKeys().hasOnly(['status']));
    }
  }
}
